  IonFabButton
} from '@ionic/react';
import { add, checkmark, time } from 'ionicons/icons';

const CleaningSchedule: React.FC = () => {
  const [selectedSegment, setSelectedSegment] = useState('today');
  const [tasks, setTasks] = useState({
    today: [
      { id: 1, task: 'Kitchen Deep Clean', time: '9:00 AM', completed: false, room: 'Kitchen' },
      { id: 2, task: 'Bathroom Sanitize', time: '2:00 PM', completed: true, room: 'Bathroom' },
      { id: 3, task: 'Living Room Vacuum', time: '4:00 PM', completed: false, room: 'Living Room' }
    ],
    week: [
      { id: 4, task: 'Bedroom Dust', time: 'Tomorrow', completed: false, room: 'Bedroom' },
      { id: 5, task: 'Kitchen Floor Mop', time: 'Wednesday', completed: false, room: 'Kitchen' },
      { id: 6, task: 'Bathroom Deep Clean', time: 'Friday', completed: false, room: 'Bathroom' }
    ],
    month: [
      { id: 7, task: 'Window Cleaning', time: 'Next Week', completed: false, room: 'All Rooms' },
      { id: 8, task: 'Carpet Deep Clean', time: 'Week 3', completed: false, room: 'Living Room' },
      { id: 9, task: 'Appliance Maintenance', time: 'Week 4', completed: false, room: 'Kitchen' }
    ]
  });

  const toggleTask = (taskId: number) => {
    setTasks(prevTasks => ({
      ...prevTasks,
      [selectedSegment]: prevTasks[selectedSegment as keyof typeof prevTasks].map(task =>
        task.id === taskId ? { ...task, completed: !task.completed } : task
      )
    }));
  };

  const currentTasks = tasks[selectedSegment as keyof typeof tasks];
  const completedCount = currentTasks.filter(task => task.completed).length;

  return (
    <IonPage>
      <IonHeader>
        <IonToolbar>
          <IonTitle>Cleaning Schedule</IonTitle>
        </IonToolbar>
      </IonHeader>
      
      <IonContent fullscreen>
        <IonHeader collapse="condense">
          <IonToolbar>
            <IonTitle size="large">Schedule</IonTitle>
          </IonToolbar>
        </IonHeader>

        <IonCard>
          <IonCardHeader>
            <IonCardTitle>Progress</IonCardTitle>
          </IonCardHeader>
          <IonCardContent>
            <div className="progress-stats">
              <h2>{completedCount}/{currentTasks.length}</h2>
              <p>Tasks Completed</p>
              <div className="progress-bar">
                <div 
                  className="progress-fill" 
                  style={{ width: `${(completedCount / currentTasks.length) * 100}%` }}
                ></div>
              </div>
            </div>
          </IonCardContent>
        </IonCard>

        <IonSegment value={selectedSegment} onIonChange={e => setSelectedSegment(e.detail.value as string)}>
          <IonSegmentButton value="today">
            <IonLabel>Today</IonLabel>
          </IonSegmentButton>
          <IonSegmentButton value="week">
            <IonLabel>This Week</IonLabel>
          </IonSegmentButton>
          <IonSegmentButton value="month">
            <IonLabel>This Month</IonLabel>
          </IonSegmentButton>
        </IonSegment>

        <IonList>
          {currentTasks.map(task => (
            <IonItem key={task.id}>
              <IonCheckbox
                slot="start"
                checked={task.completed}
                onIonChange={() => toggleTask(task.id)}
              />
              <IonLabel>
                <h2 className={task.completed ? 'completed-task' : ''}>{task.task}</h2>
                <p>{task.room}</p>
                <div className="task-meta">
                  <IonIcon icon={time} />
                  <span>{task.time}</span>
                </div>
              </IonLabel>
              {task.completed && (
                <IonBadge color="success" slot="end">
                  <IonIcon icon={checkmark} />
                </IonBadge>
              )}
            </IonItem>
          ))}
        </IonList>

        <IonFab vertical="bottom" horizontal="end" slot="fixed">
          <IonFabButton>
            <IonIcon icon={add} />
          </IonFabButton>
        </IonFab>
      </IonContent>
    </IonPage>
  );
};

export default CleaningSchedule;
